# ── 必填：鉴权 ───────────────────────────────────────────────
# 视觉后端的 API key（别名 Z_AI_API_KEY 亦可）
VISION_API_KEY=your_api_key_here

# ── 后端选型（改这 3 个即可换后端，默认 GLM）─────────────────
# 后端 profile：glm | kimi | openai | generic
VISION_PROFILE=glm
# OpenAI 兼容端点（GLM 默认）
VISION_BASE_URL=https://api.z.ai/api/paas/v4
# 视觉模型
VISION_MODEL=glm-4.6v

# 其他后端示例：
#   Kimi:   VISION_PROFILE=kimi   VISION_BASE_URL=https://api.moonshot.ai/v1     VISION_MODEL=<kimi 视觉模型>
#   OpenAI: VISION_PROFILE=openai VISION_BASE_URL=https://api.openai.com/v1      VISION_MODEL=gpt-4o
#   本地:   VISION_PROFILE=generic VISION_BASE_URL=http://localhost:8000/v1      VISION_MODEL=<本地 VLM>

# ── 安全 ─────────────────────────────────────────────────────
# 允许读取本地图片的目录（os.pathsep 分隔；为空则只允许 MCP roots / 当前工作目录）
VISION_ALLOWED_DIRS=
# 是否把 http(s) 图片 URL 直接透传给后端（默认 false：server 下载+SSRF 校验后转 data URI）
VISION_ALLOW_URL_PASSTHROUGH=false

# ── 缩放 / 媒体 ──────────────────────────────────────────────
# agentic 缩放最大轮数
VISION_MAX_ZOOM_ROUNDS=3
# 概览图降采样的最大边长（px）
VISION_MAX_EDGE_PX=1568
# 视频帧采样数量
VISION_VIDEO_FRAMES=8
# 大小上限（MB）
VISION_MAX_IMAGE_MB=10
VISION_MAX_VIDEO_MB=50

# ── 能力覆盖（一般留空，由 profile 决定）─────────────────────
# VISION_SUPPORTS_VIDEO=true
# VISION_SUPPORTS_THINKING=true
# VISION_SUPPORTS_TOOLCALLING=true
# VISION_SUPPORTS_GROUNDING=true
